{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "env.d.ts",
    "next-env.d.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
